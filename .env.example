# =============================================
# .env.example — Шаблон переменных окружения
# Скопируйте этот файл в .env.local для локальной разработки
# Никогда не коммитьте реальные значения!
# =============================================

# Supabase — Основные настройки базы данных
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend — Сервис для отправки email-уведомлений
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Опционально: URL сайта (используется для ссылок в письмах и SEO)
NEXT_PUBLIC_SITE_URL=https://autopick.ru

# =============================================
# Инструкция:
# 1. Скопируйте этот файл:
#    cp .env.example .env.local
#
# 2. Заполните реальными значениями в .env.local
#
# 3. На Railway (или другом хостинге) добавьте эти же переменные
#    в раздел Variables / Environment Variables
# =============================================